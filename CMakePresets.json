{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 10,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_STANDARD_REQUIRED": "23",
                "CMAKE_C_STANDARD": "23",
                "CMAKE_PROJECT_NAME": "rmalloc",
                "CMAKE_PROJECT_DESCRIPTION": "Romario memory allocator",
                "CMAKE_PROJECT_VERSION": "0.1",
                "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/build/lib/release",
                "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/build/bin"
            }
        },
        {
            "name": "linux-release",
            "generator": "Unix Makefiles",
            "installDir": "/usr/lib/x86_64-linux-gnu/",
            "inherits":["default"]
        },
        {
            "name": "linux-debug",
            "generator": "Unix Makefiles",
            "inherits":["default"],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/build/lib/debug"
            }
        },

        {
            "name":"windows-release",
            "inherits":["default"]
        }
    ],
    "buildPresets": [
        {
            "name": "linux-debug",
            "configurePreset": "linux-debug"
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release"
        }

    ]
}